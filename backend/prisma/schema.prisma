generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  admin
}

enum UserStatus {
  active
  suspended
}

enum RegionStatus {
  active
  activating
  inactive
}

enum OfferAvailabilityStatus {
  available
  unavailable
  uncertain
}

enum OfferConfidenceLevel {
  high
  medium
  low
}

enum ProductAliasSourceType {
  rule
  admin
  receipt
}

enum PublicSearchStrategy {
  candidate
  broad_fallback
}

enum PublicSearchSloAlertStatus {
  active
  resolved
}

enum ShoppingListStatus {
  draft
  ready
  archived
}

enum ShoppingListItemResolutionStatus {
  unresolved
  matched
  partial
  missing
}

enum ShoppingListItemBrandPreferenceMode {
  any
  preferred
  exact
}

enum ShoppingListItemPurchaseStatus {
  pending
  purchased
}

enum OptimizationMode {
  local
  global_unique
  global_full
  local_unique
  local_multi
  global_multi
}

enum OptimizationRunStatus {
  queued
  running
  completed
  failed
}

enum OptimizationCoverageStatus {
  complete
  partial
  none
}

enum OptimizationSelectionStatus {
  selected
  review
  missing
}

enum UserEntitlementPlan {
  free
  premium
}

enum UserEntitlementStatus {
  active
  trialing
  past_due
  cancelled
  expired
}

enum OptimizationTokenLedgerAction {
  grant
  consume
  refund
  expire
  admin_adjustment
  receipt_bonus
}

enum ProcessingJobType {
  optimization
  receipt_processing
}

enum ProcessingJobStatus {
  queued
  running
  completed
  failed
  retrying
  cancelled
}

enum ReceiptSourceType {
  manual_entry
  qr_code_url
  qr_code_image
  pdf_upload
  image_parse
  structured_provider
}

enum ReceiptParseStatus {
  queued
  parsed
  partial
  failed
}

enum ReceiptContributionTrustLevel {
  untrusted
  pending_review
  trusted
  rejected
}

enum ReceiptModerationStatus {
  pending
  accepted
  quarantined
  duplicate
  rejected
}

enum ReceiptRewardEligibilityStatus {
  disabled
  ineligible
  eligible_pending
  granted
}

enum CityInclusionRequestStatus {
  requested
  reviewed
  planned
  rejected
}

enum MissingProductRequestStatus {
  requested
  reviewing
  converted
  rejected
}

enum UserNotificationType {
  price_drop
  receipt_outcome
  optimization_ready
  optimization_failed
}

enum UserNotificationDeliveryChannel {
  email
  push
}

enum UserNotificationDeliveryStatus {
  queued
  sending
  retrying
  delivered
  failed
}

enum UserEmailNotificationStatus {
  pending
  verified
  unsubscribed
}

enum UserPushDevicePlatform {
  android
  ios
}

model UserAccount {
  id                      String                            @id @default(uuid()) @db.Uuid
  email                   String                            @unique
  passwordHash            String
  displayName             String
  role                    UserRole                          @default(customer)
  status                  UserStatus                        @default(active)
  preferredRegionId       String?                           @db.Uuid
  lastLoginAt             DateTime?
  createdAt               DateTime                          @default(now())
  updatedAt               DateTime                          @updatedAt
  shoppingLists           ShoppingList[]
  optimizationRuns        OptimizationRun[]
  receiptRecords          ReceiptRecord[]
  priceMismatchReports    PriceMismatchReport[]
  entitlements            UserEntitlement[]
  optimizationTokenLedger OptimizationTokenLedgerEntry[]
  locationPreferences     UserLocationPreference[]
  sessions                UserSession[]
  missingProductRequests  MissingProductRequest[]
  notifications           UserNotification[]
  notificationDeliveries  UserNotificationDeliveryAttempt[]
  emailNotificationTarget UserEmailNotificationDestination?
  pushDevices             UserPushDevice[]
  notificationPreference  UserNotificationPreference?
  preferredRegion         Region?                           @relation("UserPreferredRegion", fields: [preferredRegionId], references: [id], onDelete: SetNull)
}

model UserSession {
  id               String      @id @default(uuid()) @db.Uuid
  userId           String      @db.Uuid
  refreshTokenHash String      @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model Region {
  id                      String                   @id @default(uuid()) @db.Uuid
  slug                    String                   @unique
  name                    String
  stateCode               String                   @db.VarChar(2)
  countryCode             String                   @default("BR") @db.VarChar(2)
  implantationStatus      RegionStatus             @default(activating)
  publicSortOrder         Int                      @default(0)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  establishments          Establishment[]
  shoppingLists           ShoppingList[]
  optimizationRuns        OptimizationRun[]
  preferredByUsers        UserAccount[]            @relation("UserPreferredRegion")
  userLocationPreferences UserLocationPreference[]
}

model CityInclusionRequest {
  id           String                     @id @default(uuid()) @db.Uuid
  cityName     String
  stateCode    String                     @db.VarChar(2)
  contactName  String?
  contactEmail String?
  message      String?
  status       CityInclusionRequestStatus @default(requested)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  @@index([stateCode, cityName])
  @@index([status, createdAt])
}

model Establishment {
  id             String            @id @default(uuid()) @db.Uuid
  brandName      String
  unitName       String
  cnpj           String            @unique
  cityName       String
  neighborhood   String
  addressLine    String?
  postalCode     String?
  latitude       Decimal?          @db.Decimal(9, 6)
  longitude      Decimal?          @db.Decimal(9, 6)
  locationSource String?
  regionId       String            @db.Uuid
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  region         Region            @relation(fields: [regionId], references: [id], onDelete: Restrict)
  productOffers  ProductOffer[]
  receiptRecords ReceiptRecord[]
  preferredRuns  OptimizationRun[] @relation("PreferredEstablishment")

  @@index([regionId, isActive])
  @@index([regionId, isActive, unitName])
}

model UserLocationPreference {
  id                       String            @id @default(uuid()) @db.Uuid
  userId                   String            @db.Uuid
  regionId                 String            @db.Uuid
  label                    String
  latitude                 Decimal?          @db.Decimal(9, 6)
  longitude                Decimal?          @db.Decimal(9, 6)
  postalCode               String?
  coverageRadiusKm         Decimal           @default(5.00) @db.Decimal(5, 2)
  activeEstablishmentCount Int               @default(0)
  isDefault                Boolean           @default(false)
  locationSource           String            @default("manual")
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  region                   Region            @relation(fields: [regionId], references: [id], onDelete: Cascade)
  user                     UserAccount       @relation(fields: [userId], references: [id], onDelete: Cascade)
  optimizationRuns         OptimizationRun[]

  @@index([userId, isDefault])
  @@index([regionId])
}

model CatalogProduct {
  id                     String                  @id @default(uuid()) @db.Uuid
  slug                   String                  @unique
  name                   String
  category               String
  defaultUnit            String?
  imageUrl               String?
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  aliases                CatalogProductAlias[]
  productVariants        ProductVariant[]
  productOffers          ProductOffer[]
  shoppingListItems      ShoppingListItem[]
  missingProductRequests MissingProductRequest[]

  @@unique([name, category, defaultUnit])
  @@index([category, isActive])
}

model MissingProductRequest {
  id               String                      @id @default(uuid()) @db.Uuid
  userId           String                      @db.Uuid
  requestedName    String
  categoryHint     String?
  packageHint      String?
  notes            String?
  status           MissingProductRequestStatus @default(requested)
  catalogProductId String?                     @db.Uuid
  reviewedByUserId String?                     @db.Uuid
  reviewedAt       DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  user             UserAccount                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  catalogProduct   CatalogProduct?             @relation(fields: [catalogProductId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model UserNotificationPreference {
  id                       String      @id @default(uuid()) @db.Uuid
  userId                   String      @unique @db.Uuid
  inAppEnabled             Boolean     @default(true)
  priceDropsEnabled        Boolean     @default(true)
  receiptOutcomesEnabled   Boolean     @default(true)
  optimizationReadyEnabled Boolean     @default(true)
  emailEnabled             Boolean     @default(false)
  pushEnabled              Boolean     @default(false)
  quietHoursEnabled        Boolean     @default(false)
  quietHoursStartMinute    Int?
  quietHoursEndMinute      Int?
  quietHoursTimezone       String?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
  user                     UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserEmailNotificationDestination {
  id                    String                            @id @default(uuid()) @db.Uuid
  userId                String                            @unique @db.Uuid
  email                 String
  status                UserEmailNotificationStatus       @default(pending)
  verificationTokenHash String?                           @unique
  unsubscribeTokenHash  String                            @unique
  verifiedAt            DateTime?
  unsubscribedAt        DateTime?
  createdAt             DateTime                          @default(now())
  updatedAt             DateTime                          @updatedAt
  user                  UserAccount                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryAttempts      UserNotificationDeliveryAttempt[]

  @@index([email, status])
}

model UserPushDevice {
  id               String                            @id @default(uuid()) @db.Uuid
  userId           String                            @db.Uuid
  platform         UserPushDevicePlatform
  deviceTokenHash  String                            @unique
  deviceTokenTail  String                            @db.VarChar(16)
  provider         String                            @default("fcm")
  appVersion       String?
  locale           String?
  timezone         String?
  isActive         Boolean                           @default(true)
  revokedAt        DateTime?
  lastSeenAt       DateTime                          @default(now())
  createdAt        DateTime                          @default(now())
  updatedAt        DateTime                          @updatedAt
  user             UserAccount                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryAttempts UserNotificationDeliveryAttempt[]

  @@index([userId, isActive, lastSeenAt])
  @@index([platform, isActive])
}

model UserNotification {
  id               String                            @id @default(uuid()) @db.Uuid
  userId           String                            @db.Uuid
  type             UserNotificationType
  title            String
  message          String
  resourceType     String?
  resourceId       String?
  metadata         Json?
  readAt           DateTime?
  createdAt        DateTime                          @default(now())
  user             UserAccount                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryAttempts UserNotificationDeliveryAttempt[]

  @@index([userId, readAt, createdAt])
  @@index([type, createdAt])
}

model UserNotificationDeliveryAttempt {
  id                    String                            @id @default(uuid()) @db.Uuid
  notificationId        String                            @db.Uuid
  userId                String                            @db.Uuid
  emailDestinationId    String?                           @db.Uuid
  pushDeviceId          String?                           @db.Uuid
  channel               UserNotificationDeliveryChannel
  status                UserNotificationDeliveryStatus    @default(queued)
  attemptCount          Int                               @default(0)
  maxAttempts           Int                               @default(3)
  providerMessageId     String?
  lastFailureReason     String?
  terminalFailureReason String?
  nextAttemptAt         DateTime?
  lastAttemptAt         DateTime?
  deliveredAt           DateTime?
  createdAt             DateTime                          @default(now())
  updatedAt             DateTime                          @updatedAt
  notification          UserNotification                  @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user                  UserAccount                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailDestination      UserEmailNotificationDestination? @relation(fields: [emailDestinationId], references: [id], onDelete: SetNull)
  pushDevice            UserPushDevice?                   @relation(fields: [pushDeviceId], references: [id], onDelete: SetNull)

  @@index([status, nextAttemptAt, createdAt], map: "notification_delivery_status_due_idx")
  @@index([userId, channel, status], map: "notification_delivery_user_channel_status_idx")
  @@index([notificationId, channel, createdAt], map: "notification_delivery_notification_channel_idx")
  @@index([emailDestinationId, status], map: "notification_delivery_email_destination_idx")
  @@index([pushDeviceId, status], map: "notification_delivery_push_device_idx")
}

model CatalogProductAlias {
  id               String                 @id @default(uuid()) @db.Uuid
  catalogProductId String                 @db.Uuid
  alias            String
  sourceType       ProductAliasSourceType
  confidenceScore  Decimal                @db.Decimal(5, 2)
  createdAt        DateTime               @default(now())
  catalogProduct   CatalogProduct         @relation(fields: [catalogProductId], references: [id], onDelete: Cascade)

  @@unique([catalogProductId, alias])
}

model ProductVariant {
  id                String             @id @default(uuid()) @db.Uuid
  catalogProductId  String             @db.Uuid
  slug              String             @unique
  displayName       String
  brandName         String?
  variantLabel      String?
  packageLabel      String?
  imageUrl          String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  catalogProduct    CatalogProduct     @relation(fields: [catalogProductId], references: [id], onDelete: Cascade)
  productOffers     ProductOffer[]
  shoppingListItems ShoppingListItem[] @relation("LockedProductVariant")

  @@index([catalogProductId, isActive])
}

model ProductOffer {
  id                     String                   @id @default(uuid()) @db.Uuid
  catalogProductId       String                   @db.Uuid
  productVariantId       String                   @db.Uuid
  establishmentId        String                   @db.Uuid
  displayName            String
  packageLabel           String
  priceAmount            Decimal                  @db.Decimal(10, 2)
  basePriceAmount        Decimal?                 @db.Decimal(10, 2)
  promotionalPriceAmount Decimal?                 @db.Decimal(10, 2)
  currencyCode           String                   @default("BRL") @db.VarChar(3)
  availabilityStatus     OfferAvailabilityStatus
  confidenceLevel        OfferConfidenceLevel
  sourceType             String
  sourceReference        String?
  receiptRecordId        String?                  @db.Uuid
  receiptLineItemId      String?                  @db.Uuid
  moderationStatus       ReceiptModerationStatus?
  contributionConfidence Decimal?                 @db.Decimal(5, 2)
  observedAt             DateTime
  expiresAt              DateTime?
  isActive               Boolean                  @default(true)
  updatedAt              DateTime                 @updatedAt
  establishment          Establishment            @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  catalogProduct         CatalogProduct           @relation(fields: [catalogProductId], references: [id], onDelete: Restrict)
  productVariant         ProductVariant           @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  optimizationSelections OptimizationSelection[]
  receiptRecord          ReceiptRecord?           @relation(fields: [receiptRecordId], references: [id], onDelete: SetNull)
  receiptLineItem        ReceiptLineItem?         @relation(fields: [receiptLineItemId], references: [id], onDelete: SetNull)

  @@index([catalogProductId, isActive, observedAt])
  @@index([productVariantId, isActive, observedAt])
  @@index([establishmentId, isActive])
  @@index([productVariantId, establishmentId, isActive])
  @@index([isActive, availabilityStatus, confidenceLevel, establishmentId])
  @@index([receiptRecordId])
  @@index([moderationStatus])
}

model ShoppingList {
  id                   String                @id @default(uuid()) @db.Uuid
  userId               String                @db.Uuid
  name                 String
  preferredRegionId    String?               @db.Uuid
  status               ShoppingListStatus    @default(draft)
  shareToken           String?
  sharedAt             DateTime?
  shareRevokedAt       DateTime?
  completedAt          DateTime?
  paidTotal            Decimal?              @db.Decimal(10, 2)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  shoppingListItems    ShoppingListItem[]
  optimizationRuns     OptimizationRun[]
  priceMismatchReports PriceMismatchReport[]
  preferredRegion      Region?               @relation(fields: [preferredRegionId], references: [id], onDelete: SetNull)
  user                 UserAccount           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([shareToken, sharedAt])
}

model ShoppingListItem {
  id                               String                               @id @default(uuid()) @db.Uuid
  shoppingListId                   String                               @db.Uuid
  catalogProductId                 String?                              @db.Uuid
  lockedProductVariantId           String?                              @db.Uuid
  optimizedProductVariantId        String?                              @db.Uuid
  optimizedFromBrandPreferenceMode ShoppingListItemBrandPreferenceMode?
  optimizedAt                      DateTime?
  brandPreferenceMode              ShoppingListItemBrandPreferenceMode  @default(any)
  preferredBrandNames              String[]                             @default([])
  requestedName                    String
  quantity                         Decimal?                             @db.Decimal(10, 2)
  unitLabel                        String?
  notes                            String?
  purchaseStatus                   ShoppingListItemPurchaseStatus       @default(pending)
  purchasedAt                      DateTime?
  resolutionStatus                 ShoppingListItemResolutionStatus     @default(unresolved)
  createdAt                        DateTime                             @default(now())
  updatedAt                        DateTime                             @updatedAt
  optimizationSelections           OptimizationSelection[]
  priceMismatchReports             PriceMismatchReport[]
  catalogProduct                   CatalogProduct?                      @relation(fields: [catalogProductId], references: [id], onDelete: SetNull)
  lockedProductVariant             ProductVariant?                      @relation("LockedProductVariant", fields: [lockedProductVariantId], references: [id], onDelete: SetNull)
  shoppingList                     ShoppingList                         @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)

  @@index([shoppingListId])
  @@index([catalogProductId])
  @@index([lockedProductVariantId])
}

model PriceMismatchReport {
  id                 String            @id @default(uuid()) @db.Uuid
  userId             String            @db.Uuid
  shoppingListId     String            @db.Uuid
  shoppingListItemId String?           @db.Uuid
  expectedPrice      Decimal?          @db.Decimal(10, 2)
  reportedPrice      Decimal?          @db.Decimal(10, 2)
  reason             String?
  createdAt          DateTime          @default(now())
  shoppingList       ShoppingList      @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  shoppingListItem   ShoppingListItem? @relation(fields: [shoppingListItemId], references: [id], onDelete: SetNull)
  user               UserAccount       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([shoppingListId, createdAt])
  @@index([shoppingListItemId])
  @@index([userId, createdAt])
}

model OptimizationRun {
  id                          String                         @id @default(uuid()) @db.Uuid
  shoppingListId              String                         @db.Uuid
  userId                      String                         @db.Uuid
  mode                        OptimizationMode
  regionId                    String                         @db.Uuid
  userLocationPreferenceId    String?                        @db.Uuid
  coverageRadiusKm            Decimal?                       @db.Decimal(5, 2)
  candidateEstablishmentCount Int?
  preferredEstablishmentId    String?                        @db.Uuid
  jobId                       String?                        @unique @db.Uuid
  status                      OptimizationRunStatus          @default(queued)
  totalEstimatedCost          Decimal?                       @db.Decimal(10, 2)
  estimatedSavings            Decimal?                       @db.Decimal(10, 2)
  coverageStatus              OptimizationCoverageStatus     @default(none)
  summary                     String?
  explanationPayload          Json?
  createdAt                   DateTime                       @default(now())
  completedAt                 DateTime?
  optimizationSelections      OptimizationSelection[]
  tokenLedgerEntries          OptimizationTokenLedgerEntry[]
  processingJob               ProcessingJob?                 @relation(fields: [jobId], references: [id], onDelete: SetNull)
  preferredEstablishment      Establishment?                 @relation("PreferredEstablishment", fields: [preferredEstablishmentId], references: [id], onDelete: SetNull)
  region                      Region                         @relation(fields: [regionId], references: [id], onDelete: Restrict)
  userLocationPreference      UserLocationPreference?        @relation(fields: [userLocationPreferenceId], references: [id], onDelete: SetNull)
  shoppingList                ShoppingList                   @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  user                        UserAccount                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([shoppingListId, createdAt])
  @@index([status, createdAt])
  @@index([userLocationPreferenceId])
}

model UserEntitlement {
  id          String                @id @default(uuid()) @db.Uuid
  userId      String                @db.Uuid
  plan        UserEntitlementPlan
  status      UserEntitlementStatus
  source      String
  externalRef String?
  startsAt    DateTime              @default(now())
  endsAt      DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  user        UserAccount           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, plan, status])
  @@index([externalRef])
}

model OptimizationTokenLedgerEntry {
  id                       String                        @id @default(uuid()) @db.Uuid
  userId                   String                        @db.Uuid
  action                   OptimizationTokenLedgerAction
  amount                   Int
  idempotencyKey           String                        @unique
  source                   String
  relatedOptimizationRunId String?                       @db.Uuid
  expiresAt                DateTime?
  createdAt                DateTime                      @default(now())
  user                     UserAccount                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedOptimizationRun   OptimizationRun?              @relation(fields: [relatedOptimizationRunId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([relatedOptimizationRunId])
}

model OptimizationSelection {
  id                         String                      @id @default(uuid()) @db.Uuid
  optimizationRunId          String                      @db.Uuid
  shoppingListItemId         String                      @db.Uuid
  productOfferId             String?                     @db.Uuid
  distanceKm                 Decimal?                    @db.Decimal(6, 2)
  status                     OptimizationSelectionStatus
  estimatedCost              Decimal?                    @db.Decimal(10, 2)
  comparisonPriceAmount      Decimal?                    @db.Decimal(10, 2)
  regionalAveragePriceAmount Decimal?                    @db.Decimal(10, 2)
  savingsVsComparison        Decimal?                    @db.Decimal(10, 2)
  confidenceNotice           String?
  optimizationRun            OptimizationRun             @relation(fields: [optimizationRunId], references: [id], onDelete: Cascade)
  productOffer               ProductOffer?               @relation(fields: [productOfferId], references: [id], onDelete: SetNull)
  shoppingListItem           ShoppingListItem            @relation(fields: [shoppingListItemId], references: [id], onDelete: Cascade)

  @@index([optimizationRunId])
}

model ProcessingJob {
  id                 String              @id @default(uuid()) @db.Uuid
  queueName          String
  jobType            ProcessingJobType
  resourceType       String
  resourceId         String
  status             ProcessingJobStatus @default(queued)
  attemptCount       Int                 @default(0)
  failureReason      String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  finishedAt         DateTime?
  reviewedAt         DateTime?
  reviewedByUserId   String?             @db.Uuid
  cancelledAt        DateTime?
  cancelledByUserId  String?             @db.Uuid
  cancellationReason String?
  optimizationRun    OptimizationRun?
  receiptRecord      ReceiptRecord?
}

model ReceiptRecord {
  id                      String                         @id @default(uuid()) @db.Uuid
  userId                  String                         @db.Uuid
  establishmentId         String?                        @db.Uuid
  sourceType              ReceiptSourceType
  parseStatus             ReceiptParseStatus             @default(queued)
  storeName               String?
  storeCnpj               String?
  accessKey               String?
  sefazUrl                String?
  purchaseDate            DateTime?
  jobId                   String?                        @unique @db.Uuid
  rawReference            String?
  confidenceScore         Decimal?                       @db.Decimal(5, 2)
  duplicateKey            String?
  trustLevel              ReceiptContributionTrustLevel  @default(untrusted)
  moderationStatus        ReceiptModerationStatus        @default(pending)
  rewardEligibilityStatus ReceiptRewardEligibilityStatus @default(disabled)
  reviewReason            String?
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt
  establishment           Establishment?                 @relation(fields: [establishmentId], references: [id], onDelete: SetNull)
  lineItems               ReceiptLineItem[]
  productOffers           ProductOffer[]
  processingJob           ProcessingJob?                 @relation(fields: [jobId], references: [id], onDelete: SetNull)
  user                    UserAccount                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([establishmentId, createdAt])
  @@index([userId, createdAt])
  @@index([parseStatus, createdAt])
  @@index([accessKey])
  @@index([storeCnpj])
  @@index([duplicateKey])
  @@index([moderationStatus, createdAt])
}

model ReceiptLineItem {
  id                   String         @id @default(uuid()) @db.Uuid
  receiptRecordId      String         @db.Uuid
  ean                  String?
  rawProductName       String
  normalizedName       String
  packageSize          String?
  quantity             Decimal        @db.Decimal(10, 3)
  unitPrice            Decimal        @db.Decimal(10, 2)
  originalUnitPrice    Decimal?       @db.Decimal(10, 2)
  promotionalUnitPrice Decimal?       @db.Decimal(10, 2)
  lineTotal            Decimal        @db.Decimal(10, 2)
  currency             String         @default("BRL") @db.VarChar(3)
  matchConfidence      Decimal        @db.Decimal(5, 2)
  createdAt            DateTime       @default(now())
  receiptRecord        ReceiptRecord  @relation(fields: [receiptRecordId], references: [id], onDelete: Cascade)
  productOffers        ProductOffer[]

  @@index([receiptRecordId])
  @@index([ean])
}

model PublicSearchMetric {
  id                          String               @id @default(uuid()) @db.Uuid
  regionSlug                  String
  strategy                    PublicSearchStrategy
  durationMs                  Decimal              @db.Decimal(10, 2)
  resultCount                 Int
  candidateOfferCount         Int
  candidateProductCount       Int
  candidateVariantCount       Int
  candidateEstablishmentCount Int
  createdAt                   DateTime             @default(now())

  @@index([createdAt])
  @@index([strategy, createdAt])
  @@index([regionSlug, createdAt])
}

model PublicSearchSloAlert {
  id             String                     @id @default(uuid()) @db.Uuid
  status         PublicSearchSloAlertStatus @default(active)
  sampleCount    Int
  observedP95Ms  Decimal                    @db.Decimal(10, 2)
  targetP95Ms    Int
  reason         String
  triggeredAt    DateTime                   @default(now())
  lastNotifiedAt DateTime                   @default(now())
  resolvedAt     DateTime?

  @@index([status, triggeredAt])
}
