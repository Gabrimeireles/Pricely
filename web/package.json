{
  "name": "@pricely/web",
  "version": "0.1.0",
  "private": true,
  "description": "Vite + React web workspace for Pricely landing page and admin dashboard.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
